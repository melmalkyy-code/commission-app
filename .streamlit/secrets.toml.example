# Copy this file to secrets.toml and fill in your Supabase credentials
# In Streamlit Cloud, add these under "Secrets" in app settings

[database]
url = "postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

[auth]
# Users who can access the app
# password is bcrypt hash — generate at: https://bcrypt-generator.com/
[[auth.credentials.usernames.admin]]
name     = "Manager"
password = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
email    = "admin@surveyingexperts.com"
